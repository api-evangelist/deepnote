      "item": [
        {
          "name": "Run a notebook",
          "request": {
            "name": "Run a notebook",
            "description": {
              "content": "Starts an execution run for a notebook. Optionally run detached, execute specific blocks, include dependent blocks, and pass input values.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v2",
                "runs"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notebookId\": \"<string>\",\n  \"detached\": false,\n  \"runDependentBlocks\": true,\n  \"inputs\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Get a run",
